          "key": "A",
          "text": "婚姻關係的重新調適"
        },
        {
          "key": "B",
          "text": "調整及適應父母與成年子女的代間關係"
        },
        {
          "key": "C",
          "text": "適當協助年輕人就業、就學與婚姻"
        },
        {
          "key": "D",
          "text": "增強自己參與社區及休閒活動的能力"
        }
      ],
      "answer": "C",
      "sourceFileId": "社工師:111030:c105:s0405:Q",
      "answerSourceFileId": "社工師:111030:c105:s0405:S",
      "manualPatch": false
    },
    {
      "id": "社工師:111030:c105:s0405:q05",
      "number": 5,
      "stem": "關於家庭界限的敘述，下列何者錯誤？",
      "options": [
        {
          "key": "A",
          "text": "喪偶者因懷念配偶，會在用餐時準備另一份碗筷，這是高度的界限模糊"
