      ],
      "answer": "D",
      "sourceFileId": "社工師:100160:c902:s0701:Q",
      "answerSourceFileId": "社工師:100160:c902:s0701:S",
      "manualPatch": false
    },
    {
      "id": "社工師:100160:c902:s0701:q03",
      "number": 3,
      "stem": "災難社會工作日益受到重視，在2007 年美國社會工作教育委員會（CSWE）已提出災難管理與社會工作 新課程供參考開設，其中社會工作者在救援工作中的七項工作任務，以下何者錯誤？",
      "options": [
        {
          "key": "A",
          "text": "在災難發生前後、救援中、復原後，都應將人們的文化多樣性納入考量"
        },
        {
          "key": "B",
          "text": "開發個人、地方、組織、區域、國家，以至於跨國的災難管理策略"
        },
        {
          "key": "C",
          "text": "建立災難宣導系統，主動宣導防災教育及物資募集"
        },
        {
          "key": "D",
          "text": "以知識與技巧回應災難與創傷事件，以降低受災者的苦痛"
        }
      ],
      "answer": "C",
      "sourceFileId": "社工師:100160:c902:s0701:Q",
      "answerSourceFileId": "社工師:100160:c902:s0701:S",
      "manualPatch": false
    },
    {
