        {
          "key": "B",
          "text": "人擁有自由選擇的能力和天性，個人具有自主性或自我抉擇，所選擇的可以脫離人格特質或過去經驗"
        },
        {
          "key": "C",
          "text": "改變在人的一生當中不斷的發生，以致人格必須具備一定的穩定性來因應變動"
        },
        {
          "key": "D",
          "text": "由於發展階段是固定的，因此個體因應環境的刺激而做固定的反應"
        }
      ],
      "answer": "A",
      "sourceFileId": "社工師:105090:c107:s0605:Q",
      "answerSourceFileId": "社工師:105090:c107:s0605:S",
      "manualPatch": false
    },
