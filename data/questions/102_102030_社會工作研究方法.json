    {
      "id": "社工師:102030:c111:s0706:q01",
      "number": 1,
      "stem": "有關社會工作研究方法，下列敘述何者錯誤？",
      "options": [
        {
          "key": "A",
          "text": "量化研究傾向以解釋變項間之關係為主，而質性研究偏向以描述和探索某現象為主"
        },
        {
          "key": "B",
          "text": "無論是量化研究或是質性研究，其研究設計邏輯差不多，都是社工界常用之研究方法"
        },
        {
          "key": "C",
          "text": "量化研究採局外人取向（outsider’s view），重在以理論的觀點解釋當事者之處境與行為，而質性研究 則採局內人取向（insider’s view），重在以當事人的觀點解釋當事者之處境與行為"
        },
        {
          "key": "D",
          "text": "量化研究以演繹法（deductive method）為基礎，而質性研究以歸納法（inductive method）為基礎"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:102030:c111:s0706:Q",
      "answerSourceFileId": "社工師:102030:c111:s0706:S",
      "manualPatch": false,
      "reviewStatus": "approved",
      "reviewNote": "",
      "reviewApprovalProof": "p0-current-bank-reviewed-20260707"
    },
    {
