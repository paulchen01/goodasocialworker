    {
      "id": "社工師:105030:c107:s0605:q02",
      "number": 2,
      "stem": "有關佛洛伊德（Sigmund Freud）理論觀點的敘述，下列何者錯誤？ 理論觀點影響深遠，但缺乏實證研究的印證，部分受到心理學家質疑與修正",
      "options": [
        {
          "key": "A",
          "text": "人類行為主要是受到防衛機制（defense mechanism）所驅使，防衛機制的作用力及對其抑制都會影響人"
        },
        {
          "key": "B",
          "text": "類行為"
        },
        {
          "key": "C",
          "text": "人格架構由本我（id）、自我（ego）、超我（superego）所組成"
        },
        {
          "key": "D",
          "text": "心理動力理論認為人格的發展會經過不同的性心理階段（psychosexual stages）"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:105030:c107:s0605:Q",
      "answerSourceFileId": "社工師:105030:c107:s0605:S",
      "manualPatch": false,
      "reviewStatus": "approved",
      "reviewNote": "",
      "reviewApprovalProof": "p0-current-bank-reviewed-20260707"
    },
    {
      "id": "社工師:105030:c107:s0605:q03",
      "number": 3,
      "stem": "研究發現，成年人進入中年期時，變得更具有傳承的使命感。McAdams 及Aubin 等人所提出的傳承模型， 下列何者不是該模型的七個元素？",
      "options": [
        {
          "key": "A",
          "text": "內心渴望長存，希望被他人需要"
        },
        {
          "key": "B",
          "text": "孤立於家庭生活之外"
        },
        {
          "key": "C",
          "text": "關懷下一代的出路與生涯發展"
        },
        {
          "key": "D",
          "text": "創造、維護或貢獻個人所有"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:105030:c107:s0605:Q",
      "answerSourceFileId": "社工師:105030:c107:s0605:S",
      "manualPatch": false,
      "reviewStatus": "approved",
      "reviewNote": "",
      "reviewApprovalProof": "p0-current-bank-reviewed-20260707"
