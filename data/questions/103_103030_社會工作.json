        {
          "key": "B",
          "text": "建立居民間的正式或非正式組織"
        },
        {
          "key": "C",
          "text": "建立諮詢及交流機制"
        },
        {
          "key": "D",
          "text": "建立居民向外求助的意識感"
        }
      ],
      "answer": "D",
      "sourceFileId": "社工師:103030:c110:s0601:Q",
      "answerSourceFileId": "社工師:103030:c110:s0601:S",
      "manualPatch": false
    },
    {
