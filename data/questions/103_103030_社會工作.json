    {
      "id": "社工師:103030:c110:s0601:q09",
      "number": 9,
      "stem": "社會工作者在實施受刑人家庭支持服務應涵蓋的面向有下列四項，何者錯誤？",
      "options": [
        {
          "key": "A",
