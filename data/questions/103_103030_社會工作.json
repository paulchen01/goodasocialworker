    {
      "id": "社工師:103030:c110:s0601:q01",
      "number": 1,
      "stem": "社會工作一向具有國際性的特質，隨著全球化的趨勢，國際社會工作的發展將被更加重視，而Gray 與Fook 兩位學者在思考國際社會工作時提出應顧及四方面的緊張狀況，下列何者並非其緊張狀況之一？",
      "options": [
        {
          "key": "A",
          "text": "專業化與非專業化：專業發展與非專業之間的衝突"
        },
        {
          "key": "B",
          "text": "西方化與本土化：西方與對立的實務想法間之平衡"
        },
        {
          "key": "C",
          "text": "多元主義與普世主義：對於內在的文化偏誤之意涵與回應"
        },
        {
          "key": "D",
          "text": "全球化與在地化：全球化與在地化的趨勢同時發生"
        }
      ],
      "answer": "A",
      "sourceFileId": "社工師:103030:c110:s0601:Q",
      "answerSourceFileId": "社工師:103030:c110:s0601:S",
      "manualPatch": false
    },
