    {
      "id": "社工師:103100:c110:s0604:q01",
      "number": 1,
      "stem": "下列有關T.H. Marshall 公民權利（citizenship）的敘述，何者較為正確？",
      "options": [
        {
          "key": "A",
          "text": "社會權（social right）指個人享有自由所需的人身、言論、思想、信仰、私有財產、締約、及受司法保 護等權利"
        },
        {
          "key": "B",
          "text": "公民權（civil right）指個人享有自由所需的人身、言論、思想、信仰、私有財產、締約、及受司法保護 等權利"
        },
        {
          "key": "C",
          "text": "政治權（political right）指的是個人享有過著普遍標準文明生活，從而具有締約、及受司法保護的權利"
        },
        {
          "key": "D",
          "text": "社會權（social right）指的是參與政治力運作的權利，即參與政治組織，進行投票，並享有社會遺業的 權利"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:103100:c110:s0604:Q",
      "answerSourceFileId": "社工師:103100:c110:s0604:S",
      "manualPatch": false
    },
    {
