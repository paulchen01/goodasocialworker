      "answerSourceFileId": "社工師:100160:c902:s0706:S",
      "manualPatch": false
    },
    {
      "id": "社工師:100160:c902:s0706:q26",
      "number": 26,
      "stem": "下列有關質化資料分析編碼（coding）的敘述，何者錯誤？",
