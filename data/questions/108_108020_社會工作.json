        {
          "key": "D",
          "text": "改變"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:108020:c107:s0601:Q",
      "answerSourceFileId": "社工師:108020:c107:s0601:S",
      "manualPatch": false
