        {
          "key": "D",
          "text": "增強家庭成員的技巧與能力"
        }
      ],
      "answer": "A",
      "sourceFileId": "社工師:106030:c107:s0605:Q",
      "answerSourceFileId": "社工師:106030:c107:s0605:S",
      "manualPatch": false
    },
    {
      "id": "社工師:106030:c107:s0605:q03",
      "number": 3,
      "stem": "有關基因與環境對人類行為的影響，下列敘述何者正確？",
