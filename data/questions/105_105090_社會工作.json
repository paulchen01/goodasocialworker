      "answerSourceFileId": "社工師:105090:c107:s0601:S",
      "manualPatch": false
    },
    {
      "id": "社工師:105090:c107:s0601:q13",
      "number": 13,
      "stem": "案主動機的不足乃是因為案主之內在障礙所致，這些障礙可能導致案主的悲觀、宿命及玩世不恭，若能 給予適度的激勵，給予案主一種對難題解決和成功的意識，即為激勵的重要因素，其主要步驟不包括下 列何者？",
      "options": [
