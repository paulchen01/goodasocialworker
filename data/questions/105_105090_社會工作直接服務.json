        {
          "key": "A",
          "text": "生態系統理論"
        },
        {
          "key": "B",
          "text": "危機介入取向"
        },
        {
          "key": "C",
          "text": "任務中心取向"
        },
        {
          "key": "D",
          "text": "心理暨社會學派"
        }
      ],
      "answer": "B",
