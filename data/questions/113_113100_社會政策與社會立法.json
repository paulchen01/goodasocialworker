    {
      "id": "社工師:113100:c103:s0304:q01",
      "number": 1,
      "stem": "John Rawls 的正義理論中的差異原則，指涉讓社會中最劣勢的成員獲得最大好處。下列何人以「能 力平等」的概念批判差異原則，認為因為能力上的不平等，即便讓劣勢者獲得最大好處也無法解 決社會不平等？",
      "options": [
        {
          "key": "A",
          "text": "Robert Nozick"
        },
        {
          "key": "B",
          "text": "Amartya Sen"
        },
        {
          "key": "C",
          "text": "Iris Marion Young"
        },
        {
          "key": "D",
          "text": "Friedrich Hayek"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:113100:c103:s0304:Q",
      "answerSourceFileId": "社工師:113100:c103:s0304:S",
      "manualPatch": false
    },
    {
