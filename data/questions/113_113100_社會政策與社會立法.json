        {
          "key": "D",
          "text": "負擔成本的平等"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:113100:c103:s0304:Q",
      "answerSourceFileId": "社工師:113100:c103:s0304:S",
      "manualPatch": false
    },
    {
