        {
          "key": "B",
          "text": "與案主建立信賴的關係"
        },
        {
          "key": "C",
          "text": "若非機構職掌範圍則可協助轉介"
        },
        {
          "key": "D",
          "text": "介紹機構的功能與服務進行的方式"
        }
      ],
      "answer": "A",
      "sourceFileId": "社工師:107030:c107:s0602:Q",
      "answerSourceFileId": "社工師:107030:c107:s0602:S",
      "manualPatch": false
    },
    {
      "id": "社工師:107030:c107:s0602:q06",
      "number": 6,
      "stem": "關於會談中「面質」（confronting）技巧的運用，以下敘述何者錯誤？",
      "options": [
        {
