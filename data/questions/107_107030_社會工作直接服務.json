          "key": "A",
          "text": "整合（integration）"
        },
        {
          "key": "B",
          "text": "應用（application）"
        },
        {
          "key": "C",
          "text": "適應（adaptation）"
        },
        {
          "key": "D",
          "text": "目標達成（goal attainment）"
        }
      ],
      "answer": "B",
      "sourceFileId": "社工師:107030:c107:s0602:Q",
      "answerSourceFileId": "社工師:107030:c107:s0602:S",
      "manualPatch": false
    },
    {
